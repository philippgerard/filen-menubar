{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Filen Menubar",
  "version": "0.1.21",
  "identifier": "io.filen.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm"],
    "publisher": "Philipp Gerard",
    "copyright": "Copyright (c) 2025 Philipp Gerard",
    "licenseFile": "../LICENSE",
    "shortDescription": "A lightweight menubar app for Filen cloud sync",
    "longDescription": "Filen Menubar is a lightweight system tray application that wraps the Filen CLI to provide sync status monitoring. It runs in your system tray and shows the current sync state.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "section": "utils",
        "priority": "optional",
        "depends": ["nodejs"]
      }
    }
  }
}
